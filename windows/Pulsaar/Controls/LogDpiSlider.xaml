<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Pulsaar.Controls.LogDpiSlider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <Slider x:Name="DpiSliderControl"
                Minimum="0"
                Maximum="0"
                StepFrequency="1"
                TickPlacement="None"
                ValueChanged="DpiSlider_ValueChanged"/>
        <Canvas x:Name="TickCanvas"
                Height="28"
                Margin="12,0"/>
    </StackPanel>
</UserControl>
