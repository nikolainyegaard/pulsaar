<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Pulsaar.Controls.LogDpiSlider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <!-- Live DPI readout above the track. Matches macOS "2400 DPI" heading. -->
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
            <TextBlock x:Name="DpiReadout"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Text="DPI"
                       FontSize="13"
                       Opacity="0.55"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,1"/>
        </StackPanel>

        <Slider x:Name="DpiSliderControl"
                Minimum="0"
                Maximum="0"
                StepFrequency="1"
                TickPlacement="None"
                IsThumbToolTipEnabled="False"
                ValueChanged="DpiSlider_ValueChanged"/>

        <!-- Tick marks and labels at landmark DPI values -->
        <Canvas x:Name="TickCanvas"
                Height="28"
                Margin="12,0"/>
    </StackPanel>
</UserControl>
