<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Pulsaar.Controls.DeviceSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pulsaar.Controls">

    <Grid>
        <!-- Loading state -->
        <StackPanel x:Name="LoadingPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <ProgressRing IsActive="True"
                          Width="36" Height="36"
                          HorizontalAlignment="Center"/>
            <TextBlock Text="Reading settings..."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText"
                   Text="No configurable settings"
                   Style="{StaticResource BodyTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- Settings content -->
        <ScrollViewer x:Name="SettingsScroll"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <StackPanel Padding="24,16,24,24" Spacing="0">

                <!-- DPI section -->
                <StackPanel x:Name="DpiSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,20">
                    <TextBlock Text="DPI"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <controls:LogDpiSlider x:Name="DpiSlider"/>
                </StackPanel>

                <!-- Scroll Wheel section -->
                <StackPanel x:Name="ScrollSection" Visibility="Collapsed" Spacing="0" Margin="0,0,0,20">
                    <TextBlock Text="Scroll Wheel"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,4"/>
                    <ToggleSwitch x:Name="InvertToggle"
                                  Header="Invert direction"
                                  Visibility="Collapsed"
                                  Margin="0"
                                  Toggled="InvertToggle_Toggled"/>
                    <ToggleSwitch x:Name="HiresToggle"
                                  Header="High resolution"
                                  Visibility="Collapsed"
                                  Margin="0"
                                  Toggled="HiresToggle_Toggled"/>
                </StackPanel>

                <!-- SmartShift / Scroll Mode section -->
                <StackPanel x:Name="SmartShiftSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,20">
                    <TextBlock Text="Scroll Mode"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ComboBox x:Name="WheelModeCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="WheelModeCombo_SelectionChanged"/>
                    <StackPanel x:Name="TorquePanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Ratchet threshold"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Slider x:Name="TorqueSlider"
                                Minimum="1"
                                Maximum="100"
                                TickPlacement="None"
                                ValueChanged="TorqueSlider_ValueChanged"/>
                    </StackPanel>
                </StackPanel>

                <!-- Change Host section -->
                <StackPanel x:Name="HostsSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,20">
                    <TextBlock Text="Change Host"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ComboBox x:Name="HostCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="HostCombo_SelectionChanged"/>
                </StackPanel>

                <!-- FN Swap section -->
                <StackPanel x:Name="FnSwapSection" Visibility="Collapsed" Margin="0,0,0,20">
                    <ToggleSwitch x:Name="FnSwapToggle"
                                  Header="FN key swap"
                                  Margin="0"
                                  Toggled="FnSwapToggle_Toggled"/>
                </StackPanel>

                <!-- Set OS section -->
                <StackPanel x:Name="PlatformSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,20">
                    <TextBlock Text="Set OS"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ComboBox x:Name="PlatformCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="PlatformCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Backlight section -->
                <StackPanel x:Name="BacklightSection" Visibility="Collapsed" Spacing="8">
                    <TextBlock Text="Backlight"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ComboBox x:Name="BacklightModeCombo"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="BacklightModeCombo_SelectionChanged"/>
                    <StackPanel x:Name="BrightnessPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Brightness"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Slider x:Name="BrightnessSlider"
                                Minimum="0"
                                Maximum="100"
                                TickPlacement="None"
                                ValueChanged="BrightnessSlider_ValueChanged"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
