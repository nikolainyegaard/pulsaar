<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Pulsaar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Pulsaar"
    xmlns:controls="using:Pulsaar.Controls"
    Title="Pulsaar">

    <Grid>
        <Grid.Resources>
            <!-- Receiver row: icon + name + device count -->
            <DataTemplate x:Key="ReceiverSidebarTemplate"
                          x:DataType="local:SidebarReceiverItem">
                <Grid Height="44" Padding="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE704;" FontSize="14"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{x:Bind Receiver.Name}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="2"
                               Text="{x:Bind Receiver.Devices.Count}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>

            <!-- Device row: tree connector + kind icon + name + battery -->
            <DataTemplate x:Key="DeviceSidebarTemplate"
                          x:DataType="local:SidebarDeviceItem">
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Dashed tree connector lines -->
                    <Canvas Grid.Column="0" Width="24">
                        <!-- Vertical segment: top half (always drawn) -->
                        <Rectangle Canvas.Left="11" Canvas.Top="0"
                                   Width="1" Height="20"
                                   Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.35"/>
                        <!-- Vertical segment: bottom half (hidden for last device) -->
                        <Rectangle Canvas.Left="11" Canvas.Top="20"
                                   Width="1" Height="20"
                                   Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.35"
                                   Visibility="{x:Bind ConnectorBottomVisible}"/>
                        <!-- Horizontal arm -->
                        <Rectangle Canvas.Left="11" Canvas.Top="19"
                                   Width="13" Height="1"
                                   Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.35"/>
                    </Canvas>

                    <FontIcon Grid.Column="1" Glyph="{x:Bind KindGlyph}"
                              FontSize="13" VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0">
                        <TextBlock Text="{x:Bind Device.Name}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Offline"
                                   Visibility="{x:Bind OfflineBadgeVisible}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="4,0,10,0"
                                Visibility="{x:Bind BatteryVisible}">
                        <FontIcon Glyph="{x:Bind BatteryGlyph}" FontSize="11"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind BatteryText}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </DataTemplate>

            <!-- Bluetooth row: BT icon + label + device count -->
            <DataTemplate x:Key="BluetoothSidebarTemplate"
                          x:DataType="local:SidebarBluetoothItem">
                <Grid Height="44" Padding="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE702;" FontSize="14"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Bluetooth"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="{x:Bind Count}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </DataTemplate>

            <controls:SidebarTemplateSelector
                x:Key="SidebarSelector"
                ReceiverTemplate="{StaticResource ReceiverSidebarTemplate}"
                DeviceTemplate="{StaticResource DeviceSidebarTemplate}"
                BluetoothTemplate="{StaticResource BluetoothSidebarTemplate}"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Custom title bar: full width, registered as the drag region -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0" Grid.ColumnSpan="2"
              Background="{ThemeResource NavigationViewDefaultPaneBackground}">
            <TextBlock Text="Pulsaar"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </Grid>

        <!-- Bottom border under title bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                VerticalAlignment="Bottom" Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Sidebar background + right divider -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{ThemeResource NavigationViewDefaultPaneBackground}"
                BorderThickness="0,0,1,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Sidebar item list -->
        <ListView x:Name="SidebarList"
                  Grid.Row="1" Grid.Column="0"
                  Background="Transparent"
                  ItemTemplateSelector="{StaticResource SidebarSelector}"
                  SelectionMode="Single"
                  SelectionChanged="SidebarList_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Detail content frame -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1" Grid.Column="1"
               IsNavigationStackEnabled="False"/>
    </Grid>
</Window>
